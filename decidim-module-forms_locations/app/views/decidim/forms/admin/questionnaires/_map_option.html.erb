<% map_option = form.object %>

<div class="card questionnaire-question-map-option">
  <div class="card-divider">
    <h2 class="card-title">
    <span><%= t(".map_option") %></span>
    <% if editable %>
      <button class="button button__sm button__transparent-secondary small alert hollow remove-map-option button--title mb-2">
        <%= icon("delete-bin-line") %>
        <%= t(".remove") %>
      </button>
    <% end %>
    </h2>
  </div>

  <div class="card-section">
    <div class="row column">
      <%=
        form.translated(
          :text_field,
          :label,
          tabs_id: tabs_id_for_question_map_option(question, map_option),
          label: t(".label"),
          disabled: !editable
        )
      %>
    </div>


    <div class="row column">
      <%=
        form.translated(
          :select,
          :shape,
          tabs_id: tabs_id_for_question_map_option(question, map_option),
          label: t(".shape"),
          disabled: !editable,
          collection: [
            ["circle", t(".shapes.circle")],
            ["triangle", t(".shapes.triangle")],
            ["square", t(".shapes.square")],
            ["diamond", t(".shapes.diamond")],
            ["star", t(".shapes.star")]
          ]
        )
      %>
    </div>

    <div class="row column">
      <%=
        form.color_field(
          :color,
          tabs_id: tabs_id_for_question_map_option(question, map_option),
          label: t(".color"),
          disabled: !editable
        )
      %>
    </div>
  </div>

  <% if map_option.persisted? %>
    <%= form.hidden_field :id, disabled: !editable %>
  <% end %>

  <%= form.hidden_field :deleted, disabled: !editable %>
</div>
