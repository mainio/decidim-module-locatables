<div class="form__wrapper">
  <div class="card pt-4">
    <div class="card-section">
      <div class="row column">
        <%= form.translated :text_field, :title, autofocus: true, aria: { label: :title }, label: t("models.components.title", scope: "decidim.forms.admin") %>
      </div>
      <div class="row column">
        <%= form.translated :editor, :description, toolbar: :full, lines: 30, label: t("models.components.description", scope: "decidim.forms.admin"), aria: { label: :description } %>
      </div>
      <% if form.object.respond_to?(:requires_tos_agreement) %>
        <div class="row column" data-controls-visibility="#tos-agreement-content">
          <%= form.check_box :requires_tos_agreement, label: t("models.components.requires_tos_agreement", scope: "decidim.forms.admin") %>
        </div>
        <div id="tos-agreement-content" class="row column<%= " hidden" unless form.object.requires_tos_agreement? %>">
          <%= form.translated :editor, :tos, toolbar: :content, lines: 10, label: t("models.components.tos", scope: "decidim.forms.admin"), aria: { label: :tos } %>
        </div>
      <% else %>
        <div class="row column">
          <%= form.translated :editor, :tos, toolbar: :content, lines: 10, label: t("models.components.tos", scope: "decidim.forms.admin"), aria: { label: :tos } %>
        </div>
      <% end %>
    </div>
  </div>
</div>

